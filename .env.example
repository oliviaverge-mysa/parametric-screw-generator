# ─── Parametric Screw Generator ────────────────────────────────
# Copy this file to .env and fill in values as needed.
# All variables are optional; the app works without any of them.

# Option A (recommended): Google Gemini — free tier available.
# Get your key at https://aistudio.google.com/apikey
GEMINI_API_KEY=
GEMINI_VISION_MODEL=gemini-2.0-flash

# Option B (recommended free alternative): Groq — free tier, no credit card.
# Get your key at https://console.groq.com/keys
GROQ_API_KEY=
GROQ_VISION_MODEL=meta-llama/llama-4-scout-17b-16e-instruct

# Option C: OpenAI Vision (requires paid API key).
OPENAI_API_KEY=
OPENAI_VISION_MODEL=gpt-4o
OPENAI_BASE_URL=https://api.openai.com/v1

# Optional: author name shown on engineering drawing PDFs (default: "User").
# DRAWING_AUTHOR=Your Name

# Optional: API key to protect /api/* and /downloads/* endpoints.
# When set, all requests must include "Authorization: Bearer <key>".
# Leave blank for local development (no auth required).
# BACKEND_API_KEY=

# Optional: override the server host/port (defaults shown).
# HOST=127.0.0.1
# PORT=8007
