# ─── Parametric Screw Generator ────────────────────────────────
# Copy this file to .env and fill in values as needed.
# All variables are optional; the app works without any of them.

# Optional: enables AI-powered image detection via OpenAI Vision.
# If unset, falls back to local OpenCV-based detection (still works).
OPENAI_API_KEY=
OPENAI_VISION_MODEL=gpt-4o-mini
OPENAI_BASE_URL=https://api.openai.com/v1

# Optional: author name shown on engineering drawing PDFs (default: "User").
# DRAWING_AUTHOR=Your Name

# Optional: override the server host/port (defaults shown).
# HOST=127.0.0.1
# PORT=8007
